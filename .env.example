# Postgres (the configured adapter is @payloadcms/db-postgres)
DATABASE_URL=postgres://user:pass@127.0.0.1:5432/ecomify
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Tenant resolution: shared secret guarding /api/internal/resolve-tenant
INTERNAL_API_SECRET=CHANGE_ME

# Per-tenant payment credential encryption — 32 bytes hex (64 chars).
# Generate: openssl rand -hex 32   — keep OUT of the DB and the repo.
PAYMENT_ENC_KEY=CHANGE_ME_64_HEX_CHARS
